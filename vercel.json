{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "serralhariarinos.com" }],
      "destination": "https://www.serralhariarinos.pt/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.serralhariarinos.com" }],
      "destination": "https://www.serralhariarinos.pt/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "serralhariarinos.pt" }],
      "destination": "https://www.serralhariarinos.pt/:path*",
      "permanent": true
    }
  ]
}
